п»ҝ# Server
PORT=3002
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dacha_db
DB_USER=dacha_user
DB_PASSWORD=your_strong_password

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=30d

# Weather API (OpenWeatherMap or similar)
WEATHER_API_KEY=your_api_key_here
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# RuStore Push Notifications
# Р СҹР С•Р В»РЎС“РЎвҖЎР С‘РЎвҖҡРЎРҠ Р РҶ RuStore Р СҷР С•Р Р…РЎРғР С•Р В»РЎРҠ РІвҖ вҖҷ Push-РЎС“Р РҶР ВөР Т‘Р С•Р СҳР В»Р ВөР Р…Р С‘РЎРҸ РІвҖ вҖҷ Р СҹРЎРӮР С•Р ВөР С”РЎвҖҡРЎвҖ№
RUSTORE_PUSH_PROJECT_ID=your_rustore_project_id
# Р РҺР ВөРЎРӮР РҶР С‘РЎРғР Р…РЎвҖ№Р в„– РЎвҖҡР С•Р С”Р ВөР Р… РІРӮвҖқ Р РҶР С”Р В»Р В°Р Т‘Р С”Р В° "Р РҺР ВөРЎРӮР РҶР С‘РЎРғР Р…РЎвҖ№Р в„– РЎвҖҡР С•Р С”Р ВөР Р…" Р РҶ Р С—РЎРӮР С•Р ВөР С”РЎвҖҡР Вө Р С”Р С•Р Р…РЎРғР С•Р В»Р С‘
RUSTORE_PUSH_SERVICE_TOKEN=your_rustore_service_token

# Admin
ADMIN_EMAIL=your_admin_email@example.com

