# Server
PORT=3002
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dacha_db
DB_USER=dacha_user
DB_PASSWORD=your_strong_password

# Auth
# ВАЖНО: в production JWT_SECRET обязателен — иначе сервер не запустится.
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=30d

# CORS: список origin через запятую. Пусто = разрешить любой origin (по умолчанию).
# Пример: CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=

# Rate limit (глобальный)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Weather API (OpenWeatherMap or similar)
WEATHER_API_KEY=your_api_key_here
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# RuStore Push Notifications
# Получить в RuStore Консоль -> Push-уведомления -> Проекты
RUSTORE_PUSH_PROJECT_ID=your_rustore_project_id
# Сервисный токен -- вкладка "Сервисный токен" в проекте консоли
RUSTORE_PUSH_SERVICE_TOKEN=your_rustore_service_token

# Admin
ADMIN_EMAIL=your_admin_email@example.com

# ── Почта: подтверждение email + сброс пароля ───────────────────────────────
# Драйвер выбирается автоматически: если задан UNISENDER_GO_API_KEY → HTTP API
# (Unisender Go, порт 443); иначе если задан SMTP_HOST → SMTP; иначе почта отключена
# (коды генерируются, письма не уходят, регистрация/сброс НЕ падают).

# Вариант 1 (рекомендуется на Hetzner — исходящий SMTP там заблокирован).
# Unisender Go: транзакционная почта по HTTP API. Ключ — в кабинете Unisender Go
# (Настройки → API). Домен отправителя (studio1008.com) нужно подтвердить в кабинете (SPF/DKIM).
UNISENDER_GO_API_KEY=
UNISENDER_GO_HOST=go1.unisender.ru

# Адрес и имя отправителя (используются обоими драйверами). Должен быть на подтверждённом домене.
SMTP_FROM=noreply@studio1008.com
APP_NAME=Календарь дачника

# Вариант 2 (фолбэк): прямой SMTP. На Hetzner НЕ работает (порты 25/465/587 режутся).
# secure=true для 465 (implicit TLS); для 587 STARTTLS — secure=false.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
