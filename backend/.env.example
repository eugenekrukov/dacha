# Server
PORT=3002
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dacha_db
DB_USER=dacha_user
DB_PASSWORD=your_strong_password

# Auth
# ВАЖНО: в production JWT_SECRET обязателен — иначе сервер не запустится.
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=30d

# CORS: список origin через запятую. Пусто = разрешить любой origin (по умолчанию).
# Пример: CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=

# Rate limit (глобальный)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Weather API (OpenWeatherMap or similar)
WEATHER_API_KEY=your_api_key_here
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# RuStore Push Notifications
# Получить в RuStore Консоль -> Push-уведомления -> Проекты
RUSTORE_PUSH_PROJECT_ID=your_rustore_project_id
# Сервисный токен -- вкладка "Сервисный токен" в проекте консоли
RUSTORE_PUSH_SERVICE_TOKEN=your_rustore_service_token

# Admin
ADMIN_EMAIL=your_admin_email@example.com

# ── FCM (Firebase Cloud Messaging): пуши для gplay/samsung (устройства с Google) ───────────
# Путь к JSON сервисного аккаунта Firebase (Project Settings → Service accounts → Generate
# private key). Без него отправка через FCM отключена (rustore-токены идут через RuStore Push).
# Файл положить на VPS вне git, напр. /var/www/dacha-api/secrets/fcm-service-account.json
FCM_SERVICE_ACCOUNT_PATH=

# ── ЮKassa (YooKassa): прямые платежи картой + рекуррент (замена RuStore Billing) ──────────
# Получить в личном кабинете ЮKassa → Настройки → Магазин (Shop ID) и Секретный ключ.
# Без этих ключей биллинг отключён: /billing/create-payment отвечает 503, renewalJob пропускается
# (dev/тесты работают без реальных ключей — как с почтой/пушами).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# URL возврата после оплаты (куда ЮKassa вернёт пользователя из Custom Tab). Может быть любым
# https-адресом приложения/лендинга — клиент по возвращении сам перечитывает /auth/me.
YOOKASSA_RETURN_URL=https://dacha.studio1008.com/billing/return
# Вебхук настроить в кабинете ЮKassa → Интеграция → HTTP-уведомления:
#   https://dacha.studio1008.com/billing/webhook  (события payment.succeeded, payment.canceled)
# Режим чека:
#   on  — передаём receipt; ЮKassa фискализирует его ТОЛЬКО при подключённой онлайн-кассе (54-ФЗ),
#         иначе ОТКЛОНЯЕТ платёж. Использовать только если у магазина есть фискализация.
#   off — receipt не передаём, платёж проходит без фискализации. ⚠️ ЮKassa не получит email покупателя.
# ⚠️ ВАЖНО (с 29.12.2025): сервис ЮKassa «Чеки для самозанятых» ПРЕКРАЩЁН — доход в ФНС и чек НПД
#   самозанятый регистрирует и отправляет покупателю сам в приложении «Мой налог». Приём денег через
#   ЮKassa без изменений. Для самозанятого (нет онлайн-кассы) ставь off, иначе платежи будут падать.
YOOKASSA_RECEIPT_MODE=off
# Рекуррент (автосписания). off (по умолчанию) — разовая оплата, продление вручную (для самозанятых:
# ЮKassa запрещает автоплатежи — "This store can't make recurring payments"). on — сохранять карту
# (save_payment_method) для автопродления; включать ТОЛЬКО если менеджер ЮMoney активировал автоплатежи.
YOOKASSA_RECURRING=off

# ── «Мой налог» (ФНС, НПД 422-ФЗ): авторегистрация дохода и чеков самозанятого ──────────────
# Сервис ЮKassa «Чеки для самозанятых» прекращён 29.12.2025 → регистрируем доход сами через
# неофициальный API lknpd.nalog.ru. Включается заданием NALOG_INN + NALOG_PROXY_URL и наличием
# refresh_token (получить одноразово: node scripts/nalog-auth.js). Без них nalogJob пропускается.
# ВАЖНО: ФНС режет не-РФ IP — запросы идут через российский forward-прокси (NALOG_PROXY_URL).
# ВАЖНО: на сервере должно быть точное время (NTP), иначе ФНС отклоняет запросы.
NALOG_INN=
NALOG_PHONE=
NALOG_PROXY_URL=
# Заполнится скриптом nalog-auth.js (стабильный id устройства):
NALOG_DEVICE_ID=

# ── Почта: подтверждение email + сброс пароля ───────────────────────────────
# Драйвер выбирается автоматически по приоритету:
#   BREVO_API_KEY → Brevo (HTTP API);  иначе UNISENDER_GO_API_KEY → Unisender Go (HTTP API);
#   иначе SMTP_HOST → SMTP;  иначе почта отключена (коды генерируются, письма не уходят,
#   регистрация/сброс НЕ падают). На Hetzner исходящий SMTP заблокирован → нужен HTTP API (443).

# Вариант 1 (рекомендуется): Brevo — бесплатный тариф, подтверждение домена через CNAME/TXT.
# Ключ: кабинет Brevo → SMTP & API → API Keys. Домен (studio1008.com) подтвердить через
# Senders, Domains & Dedicated IPs → Domains (DKIM/SPF/brevo-code — записи TXT/CNAME).
BREVO_API_KEY=

# Вариант 2: Unisender Go (требует NS-делегирования трекинг-домена — reg.ru не умеет).
UNISENDER_GO_API_KEY=
UNISENDER_GO_HOST=go1.unisender.ru

# Адрес и имя отправителя (используются обоими драйверами). Должен быть на подтверждённом домене.
SMTP_FROM=noreply@studio1008.com
APP_NAME=Календарь дачника

# Вариант 2 (фолбэк): прямой SMTP. На Hetzner НЕ работает (порты 25/465/587 режутся).
# secure=true для 465 (implicit TLS); для 587 STARTTLS — secure=false.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
